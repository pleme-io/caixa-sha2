   :body "#![feature(test)]\nextern crate test;\n\nuse digest::bench_update;\nuse sha2::{Sha256, Sha512};\nuse test::Bencher;\n\nbench_update!(\n    Sha256::default();\n    sha256_10 10;\n    sha256_100 100;\n    sha256_1000 1000;\n    sha256_10000 10000;\n);\n\nbench_update!(\n    Sha512::default();\n    sha512_10 10;\n    sha512_100 100;\n    sha512_1000 1000;\n    sha512_10000 10000;\n);\n"} {:path "LICENSE-MIT"
